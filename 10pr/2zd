first_num = int(input("Введите первое число: "))
while True:
    second_num = input("Введите второе число:")
    if int(second_num) <= int(first_num):
        print("Ошибка. 2-е число должно быть > 1-го")
        continue
    break

while True:
    third_num = input("Введите третье число: ")
    if int(third_num) <= int(second_num):
        print("Ошибка. 3-е число должно быть > 2-го")
        continue
    break

print("Последовательность принята.")
