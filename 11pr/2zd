price_bull = 10
price_cow = 5
price_calf = 0.5

for num_bulls in range(0, 11):
    for num_cows in range(0, 21):
        for num_calfs in range(0, 201):
            total_cost = (num_bulls * price_bull +
                         num_cows * price_cow +
                         num_calfs * price_calf)
            if total_cost == 100:
                print(f"Быков: {num_bulls}, Коровы: {num_cows}, Телят: {num_calfs}")
